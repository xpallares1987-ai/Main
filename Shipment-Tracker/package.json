{
  "name": "shipment-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type-check": "tsc",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"index.html\"",
    "test": "vitest run --environment jsdom --coverage"
  },
  "dependencies": {
    "lucide-static": "^0.372.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
