{
  "name": "ict-opex-monorepo",
  "private": true,
  "workspaces": [
    "BPMN-Modeler",
    "Shipment-Tracker",
    "Logistics-Dashboard",
    "Shared-Utils"
  ],
  "scripts": {
    "dev:bpmn": "npm run dev -w BPMN-Modeler",
    "dev:shipment": "npm run dev -w Shipment-Tracker",
    "dev:logistics": "npm run dev -w Logistics-Dashboard",
    "build": "concurrently \"npm run build -w Shared-Utils\" \"npm run build -w BPMN-Modeler\" \"npm run build -w Shipment-Tracker\" \"npm run build -w Logistics-Dashboard\"",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write \"**/*.ts\" \"**/index.html\""
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@vite-pwa/assets-generator": "^1.0.0",
    "@vitest/mocker": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "apexcharts": "^5.10.6",
    "leaflet": "^1.9.4",
    "xlsx": "^0.18.5"
  }
}
