{
  "name": "ict-opex-monorepo",
  "private": true,
  "workspaces": [
    "BPMN-Modeler",
    "Shipment-Tracker",
    "Logistics-Dashboard"
  ],
  "scripts": {
    "dev:bpmn": "npm run dev -w BPMN-Modeler",
    "dev:shipment": "npm run dev -w Shipment-Tracker",
    "dev:logistics": "npm run dev -w Logistics-Dashboard",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write \"**/*.ts\" \"**/index.html\""
  },
  "dependencies": {
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vitest/mocker": "^4.1.5",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "@vite-pwa/assets-generator": "^1.0.0",
    "@types/node": "^20.17.19"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
