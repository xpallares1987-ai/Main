# Set default behavior to automatically normalize line endings.
* text=auto

# Force LF for shell scripts and certain web assets
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf

# Explicitly declare binary files
*.png binary
*.jpg binary
*.pdf binary
*.docx binary
*.xlsx binary
*.tgz binary
