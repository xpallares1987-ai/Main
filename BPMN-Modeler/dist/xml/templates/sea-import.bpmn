<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_SeaImport" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.16.0">
  <bpmn:process id="Process_SeaImport" name="Importación Marítima" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Import" name="Llegada de Buque al Puerto">
      <bpmn:outgoing>Flow_I1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Manifest" name="Validar Manifiesto de Carga">
      <bpmn:incoming>Flow_I1</bpmn:incoming>
      <bpmn:outgoing>Flow_I2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_I1" sourceRef="StartEvent_Import" targetRef="Task_Manifest" />
    <bpmn:task id="Task_CustomsImport" name="Presentación DUA Importación">
      <bpmn:incoming>Flow_I2</bpmn:incoming>
      <bpmn:outgoing>Flow_I3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_I2" sourceRef="Task_Manifest" targetRef="Task_CustomsImport" />
    <bpmn:task id="Task_Release" name="Levante de Mercancía">
      <bpmn:incoming>Flow_I3</bpmn:incoming>
      <bpmn:outgoing>Flow_I4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_I3" sourceRef="Task_CustomsImport" targetRef="Task_Release" />
    <bpmn:endEvent id="EndEvent_Import" name="Mercancía Entregada">
      <bpmn:incoming>Flow_I4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_I4" sourceRef="Task_Release" targetRef="EndEvent_Import" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Import">
    <bpmndi:BPMNPlane id="BPMNPlane_Import" bpmnElement="Process_SeaImport">
      <bpmndi:BPMNShape id="StartEvent_Import_di" bpmnElement="StartEvent_Import">
        <dc:Bounds x="180" y="160" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Manifest_di" bpmnElement="Task_Manifest">
        <dc:Bounds x="270" y="138" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CustomsImport_di" bpmnElement="Task_CustomsImport">
        <dc:Bounds x="430" y="138" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Release_di" bpmnElement="Task_Release">
        <dc:Bounds x="590" y="138" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Import_di" bpmnElement="EndEvent_Import">
        <dc:Bounds x="750" y="160" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_I1_di" bpmnElement="Flow_I1">
        <di:waypoint x="216" y="178" />
        <di:waypoint x="270" y="178" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I2_di" bpmnElement="Flow_I2">
        <di:waypoint x="370" y="178" />
        <di:waypoint x="430" y="178" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I3_di" bpmnElement="Flow_I3">
        <di:waypoint x="530" y="178" />
        <di:waypoint x="590" y="178" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_I4_di" bpmnElement="Flow_I4">
        <di:waypoint x="690" y="178" />
        <di:waypoint x="750" y="178" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
