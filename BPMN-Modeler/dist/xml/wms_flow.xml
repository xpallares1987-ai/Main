<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:App="http://App" id="Definitions_WMS_Flow" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collab_WMS_Flow">
    <bpmn:participant id="Part_Customer" name="Cliente / Depositante" processRef="Proc_Customer" />
    <bpmn:participant id="Part_App_WMS" name="App Warehouse Management" processRef="Proc_WMS_Internal" />
    <bpmn:messageFlow id="Msg_ASN" name="ASN / Inbound Order" sourceRef="Part_Customer" targetRef="N_START_INBOUND" />
    <bpmn:messageFlow id="Msg_PICK" name="Outbound Order" sourceRef="Part_Customer" targetRef="N_START_OUTBOUND" />
  </bpmn:collaboration>

  <bpmn:process id="Proc_WMS_Internal" isExecutable="false">
    <bpmn:laneSet id="LaneSet_WMS">
      <bpmn:lane id="Lane_Admin" name="Administración / Oficina">
        <bpmn:flowNodeRef>N_START_INBOUND</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_GRN_SYSTEM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_START_OUTBOUND</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_CREATE_SHIPMENT</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Whse" name="Almacén / Operarios">
        <bpmn:flowNodeRef>N_PHYSICAL_REC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_PUTAWAY</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_PICKING</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_PACKING</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N_DISPATCH</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="N_START_INBOUND" name="ASN Recibido">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:manualTask id="N_PHYSICAL_REC" name="Descarga y Verificación" App:icon="fa-solid fa-box-open" App:time="45" App:status="critical">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="N_GRN_SYSTEM" name="Registrar Inbound (GRN)" App:icon="fa-solid fa-right-to-bracket" App:time="10" App:status="normal">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:manualTask id="N_PUTAWAY" name="Ubicación en Estantería" App:icon="fa-solid fa-boxes-stacked" App:time="20" App:status="normal">
      <bpmn:incoming>F3</bpmn:incoming>
    </bpmn:manualTask>

    <bpmn:startEvent id="N_START_OUTBOUND" name="Orden de Salida">
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:manualTask id="N_PICKING" name="Picking de Artículos" App:icon="fa-solid fa-dolly" App:time="30" App:instances="5" App:status="critical">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="N_PACKING" name="Packing / Etiquetado" App:icon="fa-solid fa-box" App:time="15" App:status="normal">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="N_CREATE_SHIPMENT" name="Generar Albarán / B/L" App:icon="fa-solid fa-file-invoice" App:time="5" App:status="normal">
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:outgoing>F7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:manualTask id="N_DISPATCH" name="Carga Camión" App:icon="fa-solid fa-truck-fast" App:time="20" App:status="normal">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:endEvent id="N_END" name="Despachado" />
    </bpmn:manualTask>

    <bpmn:sequenceFlow id="F1" sourceRef="N_START_INBOUND" targetRef="N_PHYSICAL_REC" />
    <bpmn:sequenceFlow id="F2" sourceRef="N_PHYSICAL_REC" targetRef="N_GRN_SYSTEM" />
    <bpmn:sequenceFlow id="F3" sourceRef="N_GRN_SYSTEM" targetRef="N_PUTAWAY" />
    <bpmn:sequenceFlow id="F4" sourceRef="N_START_OUTBOUND" targetRef="N_PICKING" />
    <bpmn:sequenceFlow id="F5" sourceRef="N_PICKING" targetRef="N_PACKING" />
    <bpmn:sequenceFlow id="F6" sourceRef="N_PACKING" targetRef="N_CREATE_SHIPMENT" />
    <bpmn:sequenceFlow id="F7" sourceRef="N_CREATE_SHIPMENT" targetRef="N_DISPATCH" />
  </bpmn:process>

  <bpmn:process id="Proc_Customer" isExecutable="false" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_WMS_Flow">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_WMS_Flow">
      <bpmndi:BPMNShape id="Part_Customer_di" bpmnElement="Part_Customer" isHorizontal="true"><dc:Bounds x="160" y="40" width="1100" height="100" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Part_App_WMS_di" bpmnElement="Part_App_WMS" isHorizontal="true"><dc:Bounds x="160" y="180" width="1100" height="360" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admin_di" bpmnElement="Lane_Admin" isHorizontal="true"><dc:Bounds x="190" y="180" width="1070" height="180" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Whse_di" bpmnElement="Lane_Whse" isHorizontal="true"><dc:Bounds x="190" y="360" width="1070" height="180" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="N_START_INBOUND_di" bpmnElement="N_START_INBOUND"><dc:Bounds x="242" y="242" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_PHYSICAL_REC_di" bpmnElement="N_PHYSICAL_REC"><dc:Bounds x="330" y="410" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_GRN_SYSTEM_di" bpmnElement="N_GRN_SYSTEM"><dc:Bounds x="480" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_PUTAWAY_di" bpmnElement="N_PUTAWAY"><dc:Bounds x="630" y="410" width="100" height="80" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="N_START_OUTBOUND_di" bpmnElement="N_START_OUTBOUND"><dc:Bounds x="242" y="300" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_PICKING_di" bpmnElement="N_PICKING"><dc:Bounds x="330" y="410" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_PACKING_di" bpmnElement="N_PACKING"><dc:Bounds x="780" y="410" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_CREATE_SHIPMENT_di" bpmnElement="N_CREATE_SHIPMENT"><dc:Bounds x="930" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="N_DISPATCH_di" bpmnElement="N_DISPATCH"><dc:Bounds x="1080" y="410" width="100" height="80" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="F1_di" bpmnElement="F1"><di:waypoint x="278" y="260" /><di:waypoint x="300" y="260" /><di:waypoint x="300" y="450" /><di:waypoint x="330" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F2_di" bpmnElement="F2"><di:waypoint x="430" y="450" /><di:waypoint x="455" y="450" /><di:waypoint x="455" y="260" /><di:waypoint x="480" y="260" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F3_di" bpmnElement="F3"><di:waypoint x="580" y="260" /><di:waypoint x="605" y="260" /><di:waypoint x="605" y="450" /><di:waypoint x="630" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F4_di" bpmnElement="F4"><di:waypoint x="278" y="318" /><di:waypoint x="304" y="318" /><di:waypoint x="304" y="450" /><di:waypoint x="330" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F5_di" bpmnElement="F5"><di:waypoint x="430" y="450" /><di:waypoint x="780" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F6_di" bpmnElement="F6"><di:waypoint x="880" y="450" /><di:waypoint x="905" y="450" /><di:waypoint x="905" y="260" /><di:waypoint x="930" y="260" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F7_di" bpmnElement="F7"><di:waypoint x="1030" y="260" /><di:waypoint x="1055" y="260" /><di:waypoint x="1055" y="450" /><di:waypoint x="1080" y="450" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

