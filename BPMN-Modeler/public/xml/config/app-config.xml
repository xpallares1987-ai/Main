<?xml version="1.0" encoding="UTF-8"?>
<appConfig>
  <app>
    <name>BPMN 2.0 Interactive Modeler</name>
    <version>1.0.0</version>
    <engine>camunda 8</engine>
    <language>es</language>
  </app>

  <paths>
    <defaultDiagram>./xml/diagrams/blank-process.bpmn</defaultDiagram>
    <mainDiagram>./xml/diagrams/process-main.bpmn</mainDiagram>
    <elementTemplates>./.camunda/element-templates/</elementTemplates>
  </paths>

  <ui>
    <propertiesPanelOpen>true</propertiesPanelOpen>
    <fitViewportOnLoad>true</fitViewportOnLoad>
    <autoSave>true</autoSave>
    <statusReady>Listo</statusReady>
    <statusLoading>Cargando diagrama...</statusLoading>
    <statusImported>Diagrama cargado</statusImported>
    <statusSaved>Diagrama guardado</statusSaved>
    <statusUnsaved>Cambios sin guardar</statusUnsaved>
    <statusNoSelection>Sin selección</statusNoSelection>
  </ui>

  <zoom>
    <min>0.2</min>
    <max>4</max>
    <step>0.1</step>
  </zoom>

  <storage>
    <enabled>true</enabled>
    <diagramXmlKey>bpmn.diagram-xml</diagramXmlKey>
    <diagramNameKey>bpmn.diagram-name</diagramNameKey>
    <uiStateKey>bpmn.ui-state</uiStateKey>
  </storage>

  <download>
    <defaultFileName>diagram.bpmn</defaultFileName>
    <mimeType>application/xml;charset=utf-8</mimeType>
  </download>

  <modeler>
    <keyboardBindToWindow>true</keyboardBindToWindow>
    <camunda8>true</camunda8>
    <propertiesPanel>true</propertiesPanel>
    <zeebeSupport>true</zeebeSupport>
  </modeler>
</appConfig>


