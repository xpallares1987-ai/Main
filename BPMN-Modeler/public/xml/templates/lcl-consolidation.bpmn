<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_LCL" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.16.0">
  <bpmn:process id="Process_LCLConsolidation" name="Consolidación LCL" isExecutable="true">
    <bpmn:startEvent id="Start_LCL" name="Carga Recibida en Almacén">
      <bpmn:outgoing>Flow_LCL_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Measure" name="Pesaje y Cubicaje">
      <bpmn:incoming>Flow_LCL_1</bpmn:incoming>
      <bpmn:outgoing>Flow_LCL_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_LCL_1" sourceRef="Start_LCL" targetRef="Task_Measure" />
    <bpmn:task id="Task_Consolidate" name="Planificación de Contenedor (Consol)">
      <bpmn:incoming>Flow_LCL_2</bpmn:incoming>
      <bpmn:outgoing>Flow_LCL_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_LCL_2" sourceRef="Task_Measure" targetRef="Task_Consolidate" />
    <bpmn:task id="Task_Load" name="Carga en Contenedor Master">
      <bpmn:incoming>Flow_LCL_3</bpmn:incoming>
      <bpmn:outgoing>Flow_LCL_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_LCL_3" sourceRef="Task_Consolidate" targetRef="Task_Load" />
    <bpmn:endEvent id="End_LCL" name="Contenedor Cerrado">
      <bpmn:incoming>Flow_LCL_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_LCL_4" sourceRef="Task_Load" targetRef="End_LCL" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_LCL">
    <bpmndi:BPMNPlane id="BPMNPlane_LCL" bpmnElement="Process_LCLConsolidation">
      <bpmndi:BPMNShape id="Start_LCL_di" bpmnElement="Start_LCL">
        <dc:Bounds x="180" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Measure_di" bpmnElement="Task_Measure">
        <dc:Bounds x="270" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Consolidate_di" bpmnElement="Task_Consolidate">
        <dc:Bounds x="430" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Load_di" bpmnElement="Task_Load">
        <dc:Bounds x="590" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_LCL_di" bpmnElement="End_LCL">
        <dc:Bounds x="750" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_LCL_1_di" bpmnElement="Flow_LCL_1">
        <di:waypoint x="216" y="118" />
        <di:waypoint x="270" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LCL_2_di" bpmnElement="Flow_LCL_2">
        <di:waypoint x="370" y="118" />
        <di:waypoint x="430" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LCL_3_di" bpmnElement="Flow_LCL_3">
        <di:waypoint x="530" y="118" />
        <di:waypoint x="590" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LCL_4_di" bpmnElement="Flow_LCL_4">
        <di:waypoint x="690" y="118" />
        <di:waypoint x="750" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
