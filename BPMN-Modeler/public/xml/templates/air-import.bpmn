<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AirImport" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.16.0">
  <bpmn:process id="Process_AirImport" name="Importación Aérea" isExecutable="true">
    <bpmn:startEvent id="Start_Air" name="Aviso de Llegada Aérea">
      <bpmn:outgoing>Flow_Air_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Docs_Air" name="Revisión Documental (MAWB/HAWB)">
      <bpmn:incoming>Flow_Air_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Air_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Air_1" sourceRef="Start_Air" targetRef="Task_Docs_Air" />
    <bpmn:task id="Task_Customs_Air" name="Despacho de Aduana Urgente">
      <bpmn:incoming>Flow_Air_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Air_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Air_2" sourceRef="Task_Docs_Air" targetRef="Task_Customs_Air" />
    <bpmn:task id="Task_Delivery_Air" name="Entrega Express">
      <bpmn:incoming>Flow_Air_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Air_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Air_3" sourceRef="Task_Customs_Air" targetRef="Task_Delivery_Air" />
    <bpmn:endEvent id="End_Air" name="Carga Entregada">
      <bpmn:incoming>Flow_Air_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Air_4" sourceRef="Task_Delivery_Air" targetRef="End_Air" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Air">
    <bpmndi:BPMNPlane id="BPMNPlane_Air" bpmnElement="Process_AirImport">
      <bpmndi:BPMNShape id="Start_Air_di" bpmnElement="Start_Air">
        <dc:Bounds x="180" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Docs_Air_di" bpmnElement="Task_Docs_Air">
        <dc:Bounds x="270" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Customs_Air_di" bpmnElement="Task_Customs_Air">
        <dc:Bounds x="430" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Delivery_Air_di" bpmnElement="Task_Delivery_Air">
        <dc:Bounds x="590" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Air_di" bpmnElement="End_Air">
        <dc:Bounds x="750" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Air_1_di" bpmnElement="Flow_Air_1">
        <di:waypoint x="216" y="118" />
        <di:waypoint x="270" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Air_2_di" bpmnElement="Flow_Air_2">
        <di:waypoint x="370" y="118" />
        <di:waypoint x="430" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Air_3_di" bpmnElement="Flow_Air_3">
        <di:waypoint x="530" y="118" />
        <di:waypoint x="590" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Air_4_di" bpmnElement="Flow_Air_4">
        <di:waypoint x="690" y="118" />
        <di:waypoint x="750" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
