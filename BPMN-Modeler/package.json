{
  "name": "bpmn-modeler",
  "version": "1.0.0",
  "description": "BPMN Modeler with Vite and TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"assets/**/*.css\" \"index.html\"",
    "test": "vitest"
  },
  "dependencies": {
    "@bpmn-io/properties-panel": "^3.24.1",
    "bpmn-js": "^17.11.1",
    "bpmn-js-bpmnlint": "^0.24.0",
    "bpmn-js-properties-panel": "^5.23.0",
    "bpmnlint": "^11.11.0",
    "camunda-bpmn-js-behaviors": "^1.6.1",
    "diagram-js": "^14.11.3",
    "diagram-js-minimap": "^5.2.0",
    "tiny-invariant": "^1.3.3",
    "zeebe-bpmn-moddle": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
